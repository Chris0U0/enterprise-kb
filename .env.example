# ── Database ─────────────────────────────────────────────
POSTGRES_HOST=localhost
# 与本机 PostgreSQL 错开（本机常占 5432）；须与 docker-compose 宿主机映射端口一致
POSTGRES_PORT=5433
POSTGRES_DB=enterprise_kb
POSTGRES_USER=kb_admin
POSTGRES_PASSWORD=changeme

# ── Qdrant ───────────────────────────────────────────────
# 建议 127.0.0.1：Windows + Docker 时 localhost→IPv6 可能与端口映射不一致，出现 502
QDRANT_HOST=127.0.0.1
QDRANT_PORT=6333
QDRANT_GRPC_PORT=6334

# ── MinIO ────────────────────────────────────────────────
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=enterprise-kb
MINIO_SECURE=false

# ── Redis ────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── LLM ──────────────────────────────────────────────────
# 推荐：阿里云 DashScope OpenAI 兼容（通义千问）。在控制台创建 API Key 后填入 OPENAI_API_KEY。
LLM_PROVIDER=openai_compat
OPENAI_API_KEY=sk-dcdf2acccf0c4e5da0adc0eb71cdec0b
OPENAI_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
OPENAI_MODEL=qwen-plus
OPENAI_VISION_MODEL=qwen-vl-plus
# 若需使用 Claude，改为: LLM_PROVIDER=anthropic 并配置 ANTHROPIC_API_KEY
# ANTHROPIC_API_KEY=sk-ant-xxxxx
# ANTHROPIC_MODEL=claude-sonnet-4-20250514

# ── Embedding ────────────────────────────────────────────
BGE_M3_MODEL_PATH=BAAI/bge-m3
BGE_RERANKER_MODEL_PATH=BAAI/bge-reranker-v2-m3

# ── Application ──────────────────────────────────────────
APP_ENV=development
LOG_LEVEL=INFO
MAX_UPLOAD_SIZE_MB=100
# CORS：逗号分隔，如 http://localhost:3000,http://127.0.0.1:3000；开发可用 *
CORS_ORIGINS=*
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2
# 说明：宿主机直接跑 uvicorn/celery 时用 localhost。若用 docker-compose 中的 celery-worker，
# compose 已注入 redis://redis:6379/… 覆盖上述值，勿改 .env 为 redis 除非你只跑容器。

# ── Phase 2: Agentic RAG ────────────────────────────────
AGENTIC_MAX_STEPS=4
AGENTIC_MAX_LLM_CALLS=8
AGENTIC_TIMEOUT_SECONDS=30
AGENTIC_MIN_CONFIDENCE=0.6

# ── Phase 2: Contextual Retrieval ───────────────────────
CONTEXTUAL_RETRIEVAL_ENABLED=true
CONTEXTUAL_BATCH_SIZE=5
CONTEXTUAL_MAX_CONCURRENT=3

# ── Phase 2: Streaming ──────────────────────────────────
SSE_KEEPALIVE_SECONDS=15

# ── Phase 3: Multi-Agent ────────────────────────────────
AGENT_MAX_PARALLEL=3
AGENT_GLOBAL_TOKEN_BUDGET=16000
MULTI_AGENT_TIMEOUT=45

# ── Phase 3: GraphRAG ──────────────────────────────────
GRAPHRAG_ENABLED=true
GRAPHRAG_DOC_THRESHOLD=30
KUZU_DB_PATH=/data/kuzu_db

# ── Phase 3: RAGAS Evaluation ──────────────────────────
RAGAS_ENABLED=true
RAGAS_SAMPLE_RATE=0.05
RAGAS_DAILY_SAMPLE_SIZE=50
RAGAS_MIN_THRESHOLD=0.7
